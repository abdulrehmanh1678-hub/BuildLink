                <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n\n    ROLES {\n        SMALLINT role_id PK\n        VARCHAR role_name\n    }\n\n    USERS {\n        INT user_id PK\n        SMALLINT role_id FK\n        VARCHAR first_name\n        VARCHAR last_name\n        VARCHAR email\n        VARCHAR phone\n        VARCHAR password_hash\n        BOOLEAN is_verified\n        BOOLEAN is_active\n        DECIMAL trust_score\n        TIMESTAMP created_at\n    }\n\n    SERVICE_REGIONS {\n        INT region_id PK\n        VARCHAR country\n        VARCHAR province\n        VARCHAR city\n        VARCHAR area_name\n    }\n\n    CONSTRUCTOR_PROFILES {\n        INT constructor_id PK, FK\n        VARCHAR company_name\n        VARCHAR license_number\n        INT years_experience\n        TEXT bio\n        VARCHAR website\n        DECIMAL minimum_project_budget\n        TIMESTAMP created_at\n    }\n\n    SPECIALIZATIONS {\n        INT specialization_id PK\n        VARCHAR specialization_name\n    }\n\n    CONSTRUCTOR_SPECIALIZATIONS {\n        INT constructor_id FK\n        INT specialization_id FK\n    }\n\n    CONSTRUCTOR_SERVICE_REGIONS {\n        INT constructor_id FK\n        INT region_id FK\n    }\n\n    PLOTS {\n        INT plot_id PK\n        INT owner_id FK\n        INT region_id FK\n        TEXT street_address\n        VARCHAR postal_code\n        DECIMAL length\n        DECIMAL width\n        VARCHAR soil_type\n        VARCHAR topography\n        VARCHAR status\n        BOOLEAN has_water\n        BOOLEAN has_electricity\n        BOOLEAN has_gas\n        BOOLEAN has_sewer\n        TIMESTAMP created_at\n    }\n\n    PROJECT_REQUESTS {\n        INT request_id PK\n        INT owner_id FK\n        INT plot_id FK\n        VARCHAR project_type\n        INT number_of_floors\n        DECIMAL total_area\n        DECIMAL budget_min\n        DECIMAL budget_max\n        DATE timeline_start_date\n        INT expected_duration_months\n        TEXT descr